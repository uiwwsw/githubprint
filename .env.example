# GitHub API token for server-side data fetching.
# 로컬에서는 무토큰일 때 경량 수집 + 로컬 캐시가 동작하지만, 실제 테스트 품질을 위해 설정을 권장합니다.
GITHUB_TOKEN=

# OpenAI API key for structured analysis generation.
# 구조화된 분석 JSON 생성에 필요합니다.
OPENAI_API_KEY=

# Optional model override. Defaults to gpt-5-mini.
# 선택값. 기본값은 gpt-5-mini 입니다.
OPENAI_MODEL=gpt-5-mini

# Public site origin used for canonical and Open Graph metadata.
# canonical / OG 메타데이터 기준 주소입니다.
NEXT_PUBLIC_SITE_URL=https://gitfolio-seven.vercel.app

# Development-only fixture toggle. Never use fake data in production flows.
# 개발 전용 fixture 토글입니다. 프로덕션 경로에서는 fake data를 쓰지 않습니다.
GITFOLIO_USE_FIXTURE=0
