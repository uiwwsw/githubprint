[
  {
    "id": "language:typescript:tsconfig",
    "description": "tsconfig files are strong signals that the repository is TypeScript-based.",
    "when": {
      "any": [
        {
          "source": "rootFiles",
          "patterns": ["tsconfig.json", "tsconfig.base.json", "tsconfig.app.json"],
          "matchMode": "exact"
        }
      ]
    },
    "emit": {
      "languages": [{ "label": "TypeScript", "weight": 6 }]
    }
  },
  {
    "id": "language:typescript:github-language",
    "description": "GitHub language metadata can be used as a low-confidence TypeScript fallback.",
    "when": {
      "any": [
        {
          "source": "githubLanguage",
          "patterns": ["TypeScript"],
          "matchMode": "exact"
        }
      ]
    },
    "emit": {
      "languages": [{ "label": "TypeScript", "weight": 2.4 }]
    }
  },
  {
    "id": "language:javascript:package-json",
    "description": "package.json without TypeScript config usually indicates JavaScript-first projects.",
    "when": {
      "all": [
        {
          "source": "rootFiles",
          "patterns": ["package.json"],
          "matchMode": "exact"
        }
      ],
      "none": [
        {
          "source": "rootFiles",
          "patterns": ["tsconfig.json", "tsconfig.base.json", "tsconfig.app.json"],
          "matchMode": "exact"
        }
      ]
    },
    "emit": {
      "languages": [{ "label": "JavaScript", "weight": 3.8 }]
    }
  },
  {
    "id": "language:javascript:github-language",
    "description": "GitHub language metadata can be used as a low-confidence JavaScript fallback.",
    "when": {
      "any": [
        {
          "source": "githubLanguage",
          "patterns": ["JavaScript"],
          "matchMode": "exact"
        }
      ]
    },
    "emit": {
      "languages": [{ "label": "JavaScript", "weight": 2.2 }]
    }
  },
